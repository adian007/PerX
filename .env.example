# PerX environment template — copy to .env and adjust before running.
# See backend/app/config.py for defaults and validation behavior.

# --- Core (required in production) ---
JWT_SECRET=change-me-use-openssl-rand-hex-32
# Async Postgres — for local backend outside Docker (host localhost).
# Optional: local backend outside Docker only (POSTGRES_* is preferred; omit DATABASE_URL in Docker).
# DATABASE_URL=postgresql+asyncpg://perx_user:perx_secret@localhost:5432/perx
POSTGRES_HOST=localhost
REDIS_URL=redis://localhost:6379/0

# JSON array of allowed browser origins (required for LAN / tunnel demos)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost","http://127.0.0.1"]

# Demo endpoints (/auth/demo-info, open internal routes when key unset) — false in production
ALLOW_DEMO_MODE=false

# Protect /internal/* routes; required when ALLOW_DEMO_MODE=false
INTERNAL_API_KEY=

# --- JWT / auth ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Redis ---
REDIS_USE_MEMORY=false

# --- Recommender ---
RECOMMENDER_WARM_THRESHOLD=10

# --- Ollama (optional LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b
OLLAMA_TIMEOUT_SECONDS=5.0
OLLAMA_FORCE_FAIL=false
OLLAMA_MAX_RETRIES=0

# --- Web Push (optional) ---
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@perx.local

# --- Computer vision (cv-service included in Docker stacks) ---
# Docker Compose sets CV_SERVICE_URL=http://cv-service:8010 automatically.
# Use localhost URL only when running backend outside Docker against a local cv-service.
CV_ENABLED=true
CV_SERVICE_URL=http://localhost:8010
CV_INTERNAL_KEY=
CV_MAX_IMAGE_BYTES=5000000
CV_RESULT_TTL_SECONDS=3600
CV_REQUEST_TIMEOUT_SECONDS=8.0

# --- Background jobs ---
RECONCILE_ENABLED=false
RECONCILE_INTERVAL_SECONDS=300

# --- Docker / production stack (infra/docker-compose.prod.yml) ---
# POSTGRES_PASSWORD is the source of truth in Docker; compose constructs DATABASE_URL automatically.
POSTGRES_USER=perx_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=perx

# --- Frontend build (Vite) — leave empty in dev to use Vite proxy ---
VITE_API_URL=
